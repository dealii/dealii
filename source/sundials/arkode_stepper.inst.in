// serial Vector and BlockVector
for (S : REAL_SCALARS; V : DEAL_II_VEC_TEMPLATES)
  {
    template class SUNDIALS::ARKStepper<V<S>>;
    template class SUNDIALS::ERKStepper<V<S>>;
#if DEAL_II_SUNDIALS_VERSION_GTE(7, 2, 0)
    template class SUNDIALS::LSRKStepperSTS<V<S>>;
    template class SUNDIALS::LSRKStepperSSP<V<S>>;
#endif
  }

// parallel Vector and BlockVector
for (S : REAL_SCALARS; V : DEAL_II_VEC_TEMPLATES)
  {
    template class SUNDIALS::ARKStepper<LinearAlgebra::distributed::V<S>>;
    template class SUNDIALS::ERKStepper<LinearAlgebra::distributed::V<S>>;
#if DEAL_II_SUNDIALS_VERSION_GTE(7, 2, 0)
    template class SUNDIALS::LSRKStepperSTS<LinearAlgebra::distributed::V<S>>;
    template class SUNDIALS::LSRKStepperSSP<LinearAlgebra::distributed::V<S>>;
#endif
  }

#if defined(DEAL_II_WITH_MPI) && defined(DEAL_II_WITH_TRILINOS)
// TrilinosWrappers Vector and BlockVector
for (V : DEAL_II_VEC_TEMPLATES)
  {
    template class SUNDIALS::ARKStepper<TrilinosWrappers::MPI::V>;
    template class SUNDIALS::ERKStepper<TrilinosWrappers::MPI::V>;
#  if DEAL_II_SUNDIALS_VERSION_GTE(7, 2, 0)
    template class SUNDIALS::LSRKStepperSTS<TrilinosWrappers::MPI::V>;
    template class SUNDIALS::LSRKStepperSSP<TrilinosWrappers::MPI::V>;
#  endif
  }
#endif

#if defined(DEAL_II_WITH_MPI) && defined(DEAL_II_WITH_PETSC)
#  ifndef DEAL_II_PETSC_WITH_COMPLEX
// PETScWrappers Vector and BlockVector
for (V : DEAL_II_VEC_TEMPLATES)
  {
    template class SUNDIALS::ARKStepper<PETScWrappers::MPI::V>;
    template class SUNDIALS::ERKStepper<PETScWrappers::MPI::V>;
#    if DEAL_II_SUNDIALS_VERSION_GTE(7, 2, 0)
    template class SUNDIALS::LSRKStepperSTS<PETScWrappers::MPI::V>;
    template class SUNDIALS::LSRKStepperSSP<PETScWrappers::MPI::V>;
#    endif
  }
#  endif
#endif
