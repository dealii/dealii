#  define DEAL_II_PETSC_VERSION_LT(major,minor,subminor) \
    PETSC_VERSION_LT(major,minor,subminor)
#  define DEAL_II_PETSC_VERSION_GTE(major,minor,subminor) \
    PETSC_VERSION_GE(major,minor,subminor)
#endif

